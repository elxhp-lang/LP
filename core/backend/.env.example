# 复制为 .env 或在 shell 中 export（勿提交真实密钥）
# DATABASE_URL=sqlite:///./lp.db
# JWT_SECRET=change-me

# AI 网关（默认 stub，不发起外网请求）
# AI_PROVIDER=stub
# 使用 OpenAI 兼容接口（含 DeepSeek：https://api.deepseek.com ，模型如 deepseek-chat）
# AI_PROVIDER=openai_compatible
# AI_API_KEY=
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat
# 任务到模型的路由（可选）：task_type:model，多个用逗号分隔
# 单任务可配置候选链路（用 | 分隔），例如先高性能模型，失败自动回退
# AI_TASK_MODEL_MAP=translate:deepseek-chat|gpt-4o-mini,summarize:gpt-4o-mini
# 全局兜底模型链路（逗号分隔，会在任务链路后继续尝试）
# AI_FALLBACK_MODELS=gpt-4o-mini,gpt-3.5-turbo
# 熔断窗口：某模型在窗口内失败达到阈值后，暂时从候选中剔除
# AI_ROUTE_BLOCK_WINDOW_SEC=600
# AI_ROUTE_BLOCK_THRESHOLD=3
# AI 用量计费：每 unit 扣减金额（默认 1）
# AI_UNIT_PRICE=1
